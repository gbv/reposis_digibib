<web-fragment xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-fragment_3_0.xsd" version="3.0" metadata-complete="true"
>
    <name>reposis_digibib</name>

    <servlet>
        <servlet-name>HandbuecherRoot</servlet-name>
        <servlet-class>org.mycore.webtools.vue.MCRVueRootServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HandbuecherRoot</servlet-name>
        <url-pattern>/handbuecher/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MCRAccessKeyConfigHelperServlet</servlet-name>
        <servlet-class>org.mycore.frontend.servlets.MCRConfigHelperServlet</servlet-class>
        <init-param>
            <param-name>Properties</param-name>
            <param-value>MCR.ACL.AccessKey.Strategy.AllowedSessionPermissionTypes</param-value>
        </init-param>
    </servlet>
    <servlet-mapping>
        <servlet-name>MCRAccessKeyConfigHelperServlet</servlet-name>
        <url-pattern>/access-key-config.json</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>MCRVueContactServlet</servlet-name>
        <servlet-class>org.mycore.webtools.vue.MCRVueRootServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MCRVueContactServlet</servlet-name>
        <url-pattern>/access-key-manager/*</url-pattern>
    </servlet-mapping>

</web-fragment>